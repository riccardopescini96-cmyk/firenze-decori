{
  "name": "firenze-decori",
  "version": "1.0.0",
  "scripts": {
    "build:css": "csso css/styles.css --output css/styles.min.css",
    "build:js": "terser js/main.js --output js/main.min.js --compress --mangle",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "chokidar \"css/styles.css\" -c \"npm run build:css\"",
    "watch:js": "chokidar \"js/main.js\" -c \"npm run build:js\"",
    "watch": "npm run build && concurrently \"npm run watch:css\" \"npm run watch:js\""
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "concurrently": "^8.0.0",
    "csso-cli": "^4.0.2",
    "terser": "^5.0.0"
  }
}
